                  </a>
                )}
                
                {(!author.data.social || (!author.data.social.twitter && !author.data.social.linkedin && !author.data.social.github)) && (
                  <span class="text-xs text-gray-400 italic">Tidak ada tautan sosial</span>
                )}
              </div>

              <!-- BLOK 5: Footer -->
              <footer class="flex-none px-6 py-5 border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800">
                <a 
                  href={`/penulis/${author.slug}/`} 
                  class="flex items-center justify-center w-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 px-5 py-3 text-sm font-semibold rounded-lg hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors shadow-sm"
                >
                  Baca Semua Artikel
                </a>
              </footer>

            </article>
          ))}
        </div>


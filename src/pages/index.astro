        </h2>
        <p class="text-lg text-gray-600 dark:text-gray-300">
          Jelajahi artikel berdasarkan kategori yang Anda minati.
        </p>
      </div>

      <!-- Categories Grid with Articles -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {categoriesWithPosts.map((category) => (
          <div class="card p-6">
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center">
                <div class="text-3xl mr-4">
                  {category.name === 'Tutorial' && '📚'}
                  {category.name === 'Review' && '⭐'}
                  {category.name === 'Insight' && '💡'}
                  {category.name === 'Opini' && '💭'}
                  {!['Tutorial', 'Review', 'Insight', 'Opini'].includes(String(category.name)) && '💻'}
                </div>
                <div>
                  <h3 class="text-xl font-semibold text-gray-900 dark:text-white">
                    {category.name}
                  </h3>
                    <p class="text-sm text-gray-600 dark:text-gray-400">
                      {category.posts.length} artikel
                    </p>
                </div>
              </div>

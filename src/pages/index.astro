---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
// Import AuthorCard tidak lagi diperlukan karena UI-nya dibuat inline
import { getCollection } from 'astro:content';

// Get all posts and authors - cache data untuk mengurangi pembacaan file berulang
const allPosts = await getCollection('posts');
const allAuthors = await getCollection('authors');

// Filter published posts dan sort sekali saja
const publishedPosts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

// Get latest posts - reduced untuk faster initial load
const latestPosts = publishedPosts.slice(0, 3);

// Get unique categories dengan metode yang lebih efisien
const categorySet = new Set();
publishedPosts.forEach(post => {
  const cats = Array.isArray(post.data.category) ? post.data.category : [post.data.category];
  cats.forEach(cat => cat && categorySet.add(cat));
});

const categories = Array.from(categorySet);

// Pre-filter hanya kategori yang diperlukan untuk mengurangi iterasi
const targetCategories = new Set(['Tutorial', 'Review', 'Insight', 'Opini']);

// Hitung featured authors dengan lazy loading - ambil minimal data
const featuredAuthorsData = allAuthors.slice(0, 3).map(author => {
  const postCount = publishedPosts.filter(post =>
    Array.isArray(post.data.authors) &&
    post.data.authors.includes(author.data.name)
  ).length;

  return {
    ...author,
    postCount
  };
});

// Build categories with posts - hanya ambil data yang diperlukan
const categoriesWithPosts = categories
  .filter((name): name is string => targetCategories.has(String(name)))
  .map((name) => {
    const postsInCategory = publishedPosts.filter((post) => {
      const raw = post.data.category;
      if (!raw) return false;
      return Array.isArray(raw) ? raw.includes(String(name)) : raw === name;
    });

    return {
      name,
      slug: String(name).toLowerCase().replace(/\s+/g, '-'),
      posts: postsInCategory.slice(0, 2),
      total: postsInCategory.length,
    };
  });


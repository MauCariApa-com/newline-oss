<main class="relative w-full h-screen flex items-center justify-center p-3 bg-gray-800 text-white font-sans text-lg overflow-hidden filter contrast-[1.2] saturate-[1.3] animate-flicker crt-scanline">
  <div class="relative flex items-center overflow-hidden">
    <!-- teks 404 sebagai puisi -->
    <div class="flex flex-col text-right space-y-1 z-20">
      <span class="glitch-text opacity-0 translate-x-full animate-404-in delay-[1250ms]" data-text="404: the justice you seek does not exist">
        404: the justice you seek does not exist
      </span>
      <span class="opacity-0 translate-x-full animate-404-in delay-[1450ms]">
        truth was auctioned, and you lost the bid
      </span>
    </div>

    <!-- layer shape atas -->
    <svg viewBox="0 0 200 600" class="relative z-10 w-12 h-auto fill-gray-800 animate-remove-fill delay-[1600ms]">
      <polygon points="118.302698 8 59.5369448 66.7657528 186.487016 193.715824 14 366.202839 153.491505 505.694344 68.1413353 591.044514 200 591.044514 200 8"/>
    </svg>

    <!-- retakan -->
    <svg viewBox="0 0 200 600" class="relative z-30 w-12 h-auto -ml-12">
      <polyline class="fill-none stroke-red-500 stroke-[10px] stroke-linecap-round stroke-linejoin-round animate-draw-stroke delay-[500ms]"
        points="118.302698 8 59.5369448 66.7657528 186.487016 193.715824 14 366.202839 153.491505 505.694344 68.1413353 591.044514"/>
    </svg>

    <!-- bottom layer dan lanjut puisi -->
    <div class="relative flex items-center -ml-12 z-0">
      <svg viewBox="0 0 200 600" class="relative z-10 w-12 h-auto fill-gray-800">
        <polygon points="118.302698 8 59.5369448 66.7657528 186.487016 193.715824 14 366.202839 153.491505 505.694344 68.1413353 591.044514 0 591.044514 0 8"/>
      </svg>
      <div class="flex flex-col space-y-1 ml-3 z-20">
        <span class="opacity-0 -translate-x-full animate-404-in delay-[1650ms]">
          the system knew, but never cared
        </span>
        <span class="opacity-0 -translate-x-full animate-404-in delay-[1850ms]">
          <a href="/#" class="font-medium animate-pulse-color hover:text-red-500 focus:text-red-500 active:text-green-400">
            return to the illusion?
          </a>
        </span>
      </div>
    </div>
  </div>
</main>

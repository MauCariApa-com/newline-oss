---
import { getCollection } from 'astro:content';
import PostLayout from '../layouts/PostLayout.astro';
import PageLayout from '../layouts/PageLayout.astro';
import PrivacyLayout from '../layouts/PrivacyLayout.astro';
import { formatJakarta } from '../utils/date';
import { renderMarkdownAsync } from '../utils/markdown'; 

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const pages = await getCollection('pages');
  const listing = await getCollection('listing');

  const publishedPosts = posts.filter(p => !p.data.draft);
  const publishedListing = listing.filter(p => !p.data.draft);

  const postPaths = publishedPosts.map(p => ({ params: { slug: p.slug } }));
  const listingPaths = publishedListing.map(p => ({ params: { slug: p.slug } }));
  const pagePaths = pages.map(p => ({ params: { slug: p.slug } }));

  const allSlugs = [...publishedPosts, ...publishedListing].map(p => p.slug);
  const slugSet = new Set(allSlugs);
  const duplicateSlugs = allSlugs.filter((s, i) => allSlugs.indexOf(s) !== i);

  if (duplicateSlugs.length > 0) {
    throw new Error(
      `❌ Duplikat slug ditemukan antara posts & listing:\n` +
      duplicateSlugs.map(s => `  • ${s}`).join('\n')
    );
  }

  return [...postPaths, ...listingPaths, ...pagePaths];
}

const slug = Astro.params.slug;

const posts = await getCollection('posts');
const pages = await getCollection('pages');
const listings = await getCollection('listing');

const post = posts.find(p => p.slug === slug && !p.data.draft);
const page = pages.find(p => p.slug === slug);
const listing = listings.find(p => p.slug === slug && !p.data.draft);

const entry = post || listing || page;

if (!entry) {
  throw new Error(`404 - Konten tidak ditemukan untuk slug: "${slug}"`);
}

const { Content, headings } = await entry.render();

const pubDate = (post || listing) && entry.data.pubDate
  ? formatJakarta(entry.data.pubDate)
  : null;

const specialLayouts = {
  'privacy': PrivacyLayout,
};
const SpecialLayout = specialLayouts[slug];
---

{post || listing ? (
  <PostLayout content={entry.data} headings={headings} pubDate={pubDate}>
    <Content />
  </PostLayout>
) : SpecialLayout ? (
  <SpecialLayout content={entry.data}>
    <Content />
  </SpecialLayout>
) : (
  <PageLayout content={entry.data} headings={headings}>
    <Content />
  </PageLayout>
)}
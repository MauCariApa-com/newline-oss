---
import globalCssUrl from "../styles/global.css?url";
import { isReadyToPublish } from "../utils/dateHelpers.js";
import ReadingProgress from "../components/ReadingProgress.astro";

interface Props {
  title: string;
  description?: string;
  image?: string;
  pubDate?: Date;
  updatedDate?: Date;
  authors?: string[];
  type?: "website" | "article";
}

const {
  title,
  description = "MauCariApa.com - Platform berbagi pengetahuan teknologi, tutorial, dan insight untuk para developer dan kreator digital.",
  image,
  pubDate,
  updatedDate,
  authors,
  type = "website",
  robots
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const currentYear = new Date().getFullYear();
const googleFontUrl =
  "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Newsreader:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Google+Sans:wght@400;500;600&family=Google+Sans+Text:wght@400;500;600&family=Google+Sans+Code&display=swap";
---

<!doctype html>
<html lang="id" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" href="/#favicon.ico" type="image/svg+xml" />
    <meta name="generator" content="Newline" />

    <link
      rel="preload"
      href={globalCssUrl}
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href={globalCssUrl} /></noscript>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      href={googleFontUrl}
      as="style"
      onload="this.onload=null;this.rel='stylesheet'"
    />
    <noscript><link rel="stylesheet" href={googleFontUrl} /></noscript>

    <title>{title} - MauCariApa.com</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    {robots && <meta name="robots" content={robots} />}

  </head>

  <body class="min-h-screen flex flex-col bg-white dark:bg-gray-900">
    <ReadingProgress />

    <header
      class="bg-white dark:bg-gray-900 shadow-sm border-b sticky top-0 z-50 relative"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between items-center h-16">
          <a href="/#" class="flex items-center gap-3 text-gray-900 dark:text-white">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 -960 960 960"
              class="h-8 w-auto fill-current"
            >
              <path
                d="M480-840q75 0 140.5 28T735-735q49 49 77 114.5T840-480q0 75-28 140.5T735-225q-49 49-114.5 77T480-120q-49 0-98-10.5T296-170l43-43q24 17 63.5 25t77.5 8q127 0 213.5-86.5T780-480q0-127-86.5-213.5T480-780q-127 0-213.5 86.5T180-480q0 39 7.5 72.5T211-339l-45 45q-20-32-33-81t-13-105q0-75 28-140.5T225-735q49-49 114.5-77T480-840Zm55 519v-171L163-120l-43-43 372-372H321v-60h274v274h-60Z"
              ></path>
            </svg>
            <span class="hidden lg:block font-bold text-xl">MauCariApa.com</span>
          </a>

          <div class="hidden xl:flex ml-10 space-x-4">
            <a href="/#" class="nav-link">Beranda</a>
            <a href="/#blog/" class="nav-link">Blog</a>
            <a href="/#series/" class="nav-link">Series</a>
            <a href="/#open-source/" class="nav-link">Proyek OSS</a>
            <a href="/#kontak/" class="nav-link">Kontak</a>
            <a href="/about-us/" class="nav-link">Tentang Kami</a>
          </div>

          <div class="flex items-center space-x-3">

            <a href="/#rss.xml/" class="action-btn" aria-label="RSS Feed"
              ><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                ><path
                  d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.755-23.954-24-24v4.812z"
                ></path></svg
              ></a
            >
            <button id="search-button" class="action-btn" aria-label="Search"
              ><svg
                class="w-5 h-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path></svg
              ></button
            >
            <a
              href="/#donasi/"
              class="hidden sm:inline-flex items-center bg-[#414071] text-white px-4 py-2 rounded-md text-sm font-medium"
              ><svg
                class="w-4 h-4 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path></svg
              > Dukung Kami</a
            >
            <button
              id="mobile-menu-button"
              class="xl:hidden action-btn"
              aria-label="Toggle mobile menu"
              ><svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4 6h16M4 12h16M4 18h16"></path></svg
              ></button
            >
          </div>
        </div>
      </div>

      <div
        id="mobile-menu"
        class="hidden xl:hidden absolute top-16 left-0 w-full bg-white dark:bg-gray-900 shadow-lg border-t border-gray-200 dark:border-gray-700"
      >
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="pt-2 pb-3 space-y-1">
            <a href="/#" class="mobile-link">Beranda</a>
            <a href="/#blog/" class="mobile-link">Blog</a>
            <a href="/#series/" class="mobile-link">Series</a>
            <a href="/#open-source/" class="mobile-link">Proyek OSS</a>
            <a href="/#kodebank/" class="mobile-link">Kode Bank</a>
            <a href="/#kontak/" class="mobile-link">Kontak</a>
            <a href="/about-us/" class="mobile-link">Tentang Kami</a>
          </div>
        </div>
      </div>
    </header>

    <div id="search-modal" class="fixed inset-0 z-[60] hidden">
      <div id="search-backdrop" class="absolute inset-0 bg-black bg-opacity-50">
      </div>
      <div
        class="relative z-10 flex items-start justify-center min-h-screen p-4"
      >
        <div
          class="bg-white dark:bg-gray-800 rounded-lg shadow-xl w-full max-w-2xl overflow-hidden"
        >
          <div class="flex justify-between items-center p-4 border-b">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white">
              Cari Artikel
            </h3>
            <button id="close-search" class="text-gray-400 hover:text-gray-600" aria-label="Tutup pencarian"
              >&times;</button
            >
          </div>
          <div class="p-4">
            <div class="space-y-3">
              <input
                id="local-search-input"
                type="search"
                placeholder="Ketik untuk mencari..."
                class="w-full p-2 rounded-md border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-white focus:ring focus:ring-blue-500"
                autocomplete="off"
              />
              <ul
                id="local-search-results"
                class="max-h-80 overflow-y-auto divide-y divide-gray-200 dark:divide-gray-600"
              >
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <main class="flex-grow">
      <slot />
    </main>

    <footer
      class="bg-gray-50 dark:bg-gray-800 border-t border-gray-200 dark:border-gray-700"
    >
      <div class="max-w-7xl mx-auto py-12 px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-6 gap-8">
          <div class="col-span-1 md:col-span-2">
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-4"
            >
              MauCariApa.com
            </h3>
            <p class="text-gray-600 dark:text-gray-400 mb-4 max-w-md">
              Platform berbagi pengetahuan teknologi, tutorial, dan insight
              untuk tech enthusiasts dan kreator digital.
            </p>
            <div class="flex space-x-4">
              <a
                href="/#"
                class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300"
                title="RSS Feed"
                ><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M6.503 20.752c0 1.794-1.456 3.248-3.251 3.248-1.796 0-3.252-1.454-3.252-3.248 0-1.794 1.456-3.248 3.252-3.248 1.795.001 3.251 1.454 3.251 3.248zm-6.503-12.572v4.811c6.05.062 10.96 4.966 11.022 11.009h4.817c-.062-8.71-7.118-15.758-15.839-15.82zm0-3.368c10.58.046 19.152 8.594 19.183 19.188h4.817c-.03-13.231-10.755-23.954-24-24v4.812z"
                  ></path></svg
                ></a
              >
              <a
                href="https://github.com/MauCariApa-com"
                class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300"
                target="_blank"
                rel="noopener nofollow noreferrer"
                ><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
                  ></path></svg
                ></a
              >
              <a
                href="https://www.linkedin.com/company/71663609"
                class="text-gray-400 hover:text-gray-500 dark:hover:text-gray-300"
                target="_blank"
                rel="noopener nofollow noreferrer"
                ><svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
                  ></path></svg
                ></a
              >
            </div>
          </div>
          <div>
            <h4
              class="text-sm font-semibold text-gray-900 dark:text-white mb-4"
            >
              Tentang
            </h4><ul class="space-y-2">
              <li>
                <a href="/#/" class="footer-link">Tentang Kami</a>
              </li><li><a href="/#kontak/" class="footer-link">Kontak</a></li><li>
                <a href="/#/" class="footer-link">Branding</a>
              </li><li>
                <a href="/#/" class="footer-link">Proyek OSS</a>
              </li>
            </ul>
          </div>
          <div>
            <h4
              class="text-sm font-semibold text-gray-900 dark:text-white mb-4"
            >
              Navigasi
            </h4><ul class="space-y-2">
              <li>
                <a href="/#/" class="footer-link">Kontributor</a>
              </li><li>
                <a href="/#/" class="footer-link">Kode Bank</a>
              </li><li>
                <a href="/#/" class="footer-link">Kerjasama</a>
              </li><li><a href="https://status.maucariapa.com" class="footer-link">Status</a></li>
            </ul>
          </div>
          <div>
            <h4
              class="text-sm font-semibold text-gray-900 dark:text-white mb-4"
            >
              Legal
            </h4><ul class="space-y-2">
              <li>
                <a href="/#/" class="footer-link"
                  >Syarat & Ketentuan</a
                >
              </li><li>
                <a href="/#/" class="footer-link">Sanggahan</a>
              </li><li>
                <a href="/#/" class="footer-link">Afiliasi</a>
              </li><li>
                <a href="/privacy/" class="footer-link"
                  >Kebijakan Privasi</a
                >
              </li>
            </ul>
          </div>
        </div>
        <div
          class="mt-8 pt-8 border-t border-gray-200 dark:border-gray-700 text-center"
        >
          <p class="text-center text-gray-600 dark:text-gray-400">
            &copy; {currentYear} MauCariApa.com. Powered by <a
              href="/#/"
              target="_blank"
              rel="noopener noreferrer"
              aria-label="Pelajari Newline"
              class="inline-block ml-0 mr-2 text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-blue-400"
              ><i><b>Newline</b></i></a
            >
          </p>
        </div>
      </div>
    </footer>

    <script>
      window.addEventListener("DOMContentLoaded", () => {
        const btn = document.getElementById("mobile-menu-button");
        const menu = document.getElementById("mobile-menu");
        if (!btn || !menu) return;
        btn.addEventListener("click", () => menu.classList.toggle("hidden"));
        window.addEventListener("resize", () => {
          if (window.innerWidth >= 1280) menu.classList.add("hidden");
        });

        document.addEventListener("click", (e) => {
          if (
            !menu.classList.contains("hidden") &&
            e.target instanceof Node &&
            !menu.contains(e.target) &&
            !btn.contains(e.target)
          ) {
            menu.classList.add("hidden");
          }
        });

        const searchBtn = document.getElementById("search-button");
        const modal = document.getElementById("search-modal");
        const backdrop = document.getElementById("search-backdrop");
        const closeBtn = document.getElementById("close-search");
        function openModal() {
          modal.classList.remove("hidden");
        }
        function closeModal() {
          modal.classList.add("hidden");
        }
        searchBtn?.addEventListener("click", openModal);
        closeBtn?.addEventListener("click", closeModal);
        backdrop?.addEventListener("click", closeModal);
        document.addEventListener("keydown", (e) => {
          if ((e.ctrlKey || e.metaKey) && e.key === "k") {
            e.preventDefault();
            openModal();
          }
          if (e.key === "Escape") closeModal();
        });
      });
    </script>

    <style>
      .action-btn {
        @apply p-2 rounded-md hover:bg-gray-100 dark:hover:bg-gray-700 text-gray-500 dark:text-gray-300 transition-colors;
      }
      .nav-link {
        @apply px-3 py-2 rounded-md text-sm font-medium text-gray-500 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors;
      }
      .mobile-link {
        @apply block px-3 py-2 rounded-md text-base font-medium text-gray-500 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors;
      }
      .footer-link {
        @apply text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white;
      }
    </style>
  </body>
</html>
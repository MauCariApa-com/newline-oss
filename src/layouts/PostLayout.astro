---
import BaseLayout from "./BaseLayout.astro";
import TableOfContents from "../components/TableOfContents.astro";
import { getCollection } from "astro:content";
import { formatJakarta } from "../utils/date";

export interface Props {
  content: {
    title: string;
    description?: string;
    pubDate?: string | Date;
    updatedDate?: string | Date;
    authors?: string[];
    editors?: string[];
    heroImage?: string;
    category?: string | string[];
    tags?: string[];
    series?: string;
  };
  headings: any[];
  post: any;
}

const { content, headings, post } = Astro.props;
const {
  title,
  description,
  pubDate,
  updatedDate,
  authors = [],
  editors = [],
  heroImage,
  category = [],
  tags = [],
  series,
} = content;

const displayPub = pubDate
  ? formatJakarta(pubDate, "DD/MM/YYYY")
  : "Tanggal tidak tersedia";

const displayUpdated = updatedDate
  ? formatJakarta(updatedDate, "DD/MM/YYYY")
  : null;

const slugify = (str: string) =>
  String(str)
    .toLowerCase()
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-+|-+$/g, "");

const authorsData = await getCollection("authors");
const postAuthors = authors
  .map((raw) => {
    const key = slugify(raw);
    return (
      authorsData.find((a) => a.slug === key) ??
      authorsData.find((a) => a.id === key) ??
      authorsData.find((a) => slugify(a.data.name) === key)
    );
  })
  .filter(Boolean);

let editorsData: any[] = [];
try {
  editorsData = await getCollection("editors");
} catch (_) {
  editorsData = [];
}
const postEditors = (editors || [])
  .map((raw) => {
    const key = slugify(raw);
    return (
      editorsData.find((e) => e.slug === key) ??
      editorsData.find((e) => e.id === key) ??
      editorsData.find((e) => slugify(e.data.name) === key)
    );
  })
  .filter(Boolean);

const allPosts = await getCollection("posts");
const currentSlug = post?.slug ?? Astro.params.slug;
const tagMatches =
  Array.isArray(tags) && tags.length > 0
    ? allPosts.filter(
        (p) =>
          !p.data.draft &&
          p.slug !== currentSlug &&
          Array.isArray(p.data.tags) &&
          p.data.tags.some((t) => tags.includes(t)),
      )
    : [];
const fallbackMatches = allPosts
  .filter(
    (p) =>
      !p.data.draft &&
      p.slug !== currentSlug &&
      !tagMatches.some((r) => r.slug === p.slug),
  )
  .sort(
    (a, b) =>
      new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime(),
  );
const allRelatedPosts = [...tagMatches, ...fallbackMatches];
const bottomRelatedPosts = allRelatedPosts.slice(0, 4);
const sidebarRelatedPosts = allRelatedPosts.slice(4, 8);

const allContrib = await getCollection("contributors");
const monthlyContribItems = allContrib
  .filter((item) => item.data.isMonthly)
  .map((item) => item.data.name);
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  pubDate={pubDate ? new Date(pubDate) : undefined}
  updatedDate={updatedDate ? new Date(updatedDate) : undefined}
  authors={authors}
  type="article"
>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-12 lg:gap-8">
      <!-- Main Content -->
      <article class="lg:col-span-8">
        {
          heroImage && (
            <div class="mb-8">
              <img
                src={heroImage}
                alt={`Gambar hero untuk ${title}`}
                class="w-full h-64 md:h-96 object-cover rounded-md solid border"
              />
            </div>
          )
        }

        <header class="mb-8">
          <div class="mb-4 flex flex-wrap gap-2">
            {
              Array.isArray(category) ? (
                category.map((cat) => (
                  <a
                    href={`/kategori/${slugify(cat)}/`}
                    class="inline-block bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200 px-3 py-1 rounded-full text-sm font-medium"
                  >
                    {cat}
                  </a>
                ))
              ) : (
                <a
                  href={`/kategori/${slugify(category)}/`}
                  class="inline-block bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200 px-3 py-1 rounded-full text-sm font-medium"
                >
                  {category}
                </a>
              )
            }

            {
              series && (
                <span class="inline-block bg-primary-100 text-primary-800 dark:bg-primary-900 dark:text-primary-200 px-3 py-1 rounded-full text-sm font-medium">
                  Series: {series}
                </span>
              )
            }
          </div>

          <h1
            class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-4"
          >
            {title}
          </h1>

          <div class="text-sm text-gray-600 dark:text-gray-400 mb-6">
            <!-- Desktop Meta -->
            <div class="hidden sm:flex items-center justify-between">
              <div class="flex items-center gap-4 text-sm text-gray-600 dark:text-gray-400">

                <!-- Published -->
                <div class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <path d="M16 2v4M8 2v4M3 10h18" />
                  </svg>
                  <span>{displayPub}</span>
                </div>

                <!-- Updated -->
                {
                  displayUpdated && (
                    <div class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 12a9 9 0 1 0 9-9" />
                        <path d="M12 7v5l3 3" />
                      </svg>
                      <span>{displayUpdated}</span>
                    </div>
                  )
                }
              </div>

              {
                postAuthors.length > 0 && (
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <circle cx="12" cy="7" r="4" />
                      <path d="M5.5 21a6.5 6.5 0 0 1 13 0" />
                    </svg>

                    <div class="flex -space-x-2">
                      {postAuthors.map(
                        (author) =>
                          author && (
                            <a
                              href={`/penulis/${author.slug}/`}
                              class="relative inline-block w-7 h-7 rounded-full ring-2 ring-white dark:ring-gray-900 hover:ring-primary-500 transition-all"
                              title={author.data.name}
                            >
                              {author.data.avatar ? (
                                <img
                                  src={author.data.avatar}
                                  alt={author.data.name}
                                  class="w-7 h-7 rounded-full object-cover"
                                />
                              ) : (
                                <div class="w-7 h-7 rounded-full bg-primary-600 flex items-center justify-center text-white text-sm font-medium">
                                  {author.data.name.charAt(0)}
                                </div>
                              )}
                            </a>
                          ),
                      )}
                    </div>
                  </div>
                )
              }
            </div>
            <!-- Mobile Meta -->
            <div class="sm:hidden space-y-3">
              <div class="flex items-center gap-3 text-sm text-gray-600 dark:text-gray-400">
                <div class="flex items-center gap-1.5">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <rect x="3" y="4" width="18" height="18" rx="2" />
                    <path d="M16 2v4M8 2v4M3 10h18" />
                  </svg>
                  <span>{displayPub}</span>
                </div>
                {
                  displayUpdated && (
                    <div class="flex items-center gap-1.5">
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M3 12a9 9 0 1 0 9-9" />
                        <path d="M12 7v5l3 3" />
                      </svg>
                      <span>{displayUpdated}</span>
                    </div>
                  )
                }
              </div>

              {
                postAuthors.length > 0 && (
                  <div class="flex items-center gap-2">
                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <circle cx="12" cy="7" r="4" />
                      <path d="M5.5 21a6.5 6.5 0 0 1 13 0" />
                    </svg>

                    <div class="flex -space-x-2">
                      {postAuthors.map(
                        (author) =>
                          author && (
                            <a
                              href={`/penulis/${author.slug}/`}
                              class="relative inline-block w-7 h-7 rounded-full ring-2 ring-white dark:ring-gray-900"
                              title={author.data.name}
                            >
                              {author.data.avatar ? (
                                <img
                                  src={author.data.avatar}
                                  alt={author.data.name}
                                  class="w-7 h-7 rounded-full object-cover"
                                />
                              ) : (
                                <div class="w-7 h-7 rounded-full bg-primary-600 flex items-center justify-center text-white text-sm font-medium">
                                  {author.data.name.charAt(0)}
                                </div>
                              )}
                            </a>
                          ),
                      )}
                    </div>
                  </div>
                )
              }
            </div>

          </div>
        </header>

        <!-- Table of Contents (Mobile/Tablet Portrait) -->
        <div class="lg:hidden mb-8">
          <TableOfContents headings={headings} />
        </div>

        <!-- Markdown Content -->
        <div class="prose dark:prose-invert max-w-none lg:prose-lg">
          <slot />
        </div>

        {/* <AdSpace space="post-footer-horizontal" client:visible /> */}

        <!-- CTA Sections -->
        <div class="mt-12 space-y-8">
          <!-- Article Topics -->
          {
            tags && tags.length > 0 && (
              <div class="card p-6">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4 flex items-center">
                  <svg
                    class="w-5 h-5 mr-2"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.99 1.99 0 013 12V7a4 4 0 014-4z"
                    />
                  </svg>
                  Topik dalam Artikel Ini
                </h3>
                <div class="flex flex-wrap gap-3">
                  {tags.map((tag) => (
                    <span
                      href={`/topik/${tag.toLowerCase().replace(/\s+/g, "-")}/`}
                      class="inline-flex items-center bg-primary-50 text-primary-700 dark:bg-primary-900/30 dark:text-primary-300 px-4 py-2 rounded-full text-sm font-medium hover:bg-primary-100 dark:hover:bg-primary-900/50 transition-colors"
                    >
                      <svg
                        class="w-4 h-4 mr-2"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M9 5l7 7-7 7"
                        />
                      </svg>
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            )
          }

          <!-- Comments Section -->
          <div class="card p-6">
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-6 flex items-center"
            >
              <svg
                class="w-5 h-5 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"
                ></path></svg
              >
              Diskusi & Komentar
            </h3>
            <div class="mt-8 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg">
              <h5
                class="text-sm font-medium text-gray-900 dark:text-white mb-2"
              >
                Panduan Komentar
              </h5>
              <ul class="text-xs text-gray-600 dark:text-gray-400 space-y-1">
                <li>• Gunakan bahasa yang sopan dan konstruktif</li>
                <li>• Hindari spam, promosi, atau link yang tidak relevan</li>
                <li>• Komentar akan terus dipantau secara berkala</li>
              </ul>
            </div>
            <div class="space-y-4 mb-8">
                <form>
                  <script
                    data-repo="[ENTER REPO HERE]"
                    data-repo-id="[ENTER REPO ID HERE]"
                    data-category="[ENTER CATEGORY NAME HERE]"
                    data-category-id="[ENTER CATEGORY ID HERE]"
                    data-mapping="url"
                    data-strict="0"
                    data-reactions-enabled="1"
                    data-emit-metadata="0"
                    data-input-position="top"
                    data-theme="catppuccin_latte"
                    data-lang="id"
                    data-loading="lazy"
                    crossorigin="anonymous"
                    async></script>
                </form>
            </div>
            <h2>Your comment system here</h2>
          </div>
        </div>

        <footer
          class="mt-12 pt-8 border-t border-gray-200 dark:border-gray-700"
        >
          {
            postAuthors.length > 0 && (
              <div class="mb-8">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
                  Tentang Penulis
                </h3>
                <div class="grid gap-6">
                  {postAuthors.map(
                    (author) =>
                      author && (
                        <div class="flex flex-col items-center text-center space-y-4 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg md:flex-row md:items-start md:text-left md:space-y-0 md:space-x-4">
                          <a
                            href={`/penulis/${author.slug}/`}
                            class="block md:flex-shrink-0"
                          >
                            {author.data.avatar ? (
                              <img
                                src={author.data.avatar}
                                alt={author.data.name}
                                loading="lazy"
                                class="w-8 h-8 rounded-full object-cover"
                              />
                            ) : (
                              <div class="w-16 h-16 rounded-full bg-primary-600 flex items-center justify-center text-white text-xl font-medium">
                                {author.data.name.charAt(0)}
                              </div>
                            )}
                          </a>
                          <div class="flex flex-col">
                            <h4 class="font-semibold text-gray-900 dark:text-white">
                              <a
                                href={`/penulis/${author.slug}/`}
                                class="hover:text-primary-600 dark:hover:text-primary-400"
                              >
                                {author.data.name}
                              </a>
                            </h4>
                            {author.data.bio && (
                              <p class="text-gray-600 dark:text-gray-400 mt-1">
                                {author.data.bio}
                              </p>
                            )}
                            {author.data.social && (
                              <div class="flex space-x-3 mt-3 justify-center md:justify-start">
                                {author.data.social.twitter && (
                                  <a
                                    href={`https://twitter.com/${author.data.social.twitter}`}
                                    class="text-gray-400 hover:text-blue-500 transition-colors"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                  >
                                    <svg
                                      class="w-5 h-5"
                                      fill="currentColor"
                                      viewBox="0 0 24 24"
                                    >
                                      <path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" />
                                    </svg>
                                  </a>
                                )}
                                {author.data.social.github && (
                                  <a
                                    href={`https://github.com/${author.data.social.github}`}
                                    class="text-gray-400 hover:text-gray-900 dark:hover:text-white transition-colors"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                  >
                                    <svg
                                      class="w-5 h-5"
                                      fill="currentColor"
                                      viewBox="0 0 24 24"
                                    >
                                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                                    </svg>
                                  </a>
                                )}
                                {author.data.social.linkedin && (
                                  <a
                                    href={`https://linkedin.com/in/${author.data.social.linkedin}`}
                                    class="text-gray-400 hover:text-blue-600 transition-colors"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                  >
                                    <svg
                                      class="w-5 h-5"
                                      fill="currentColor"
                                      viewBox="0 0 24 24"
                                    >
                                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                                    </svg>
                                  </a>
                                )}
                              </div>
                            )}
                          </div>
                        </div>
                      ),
                  )}
                </div>
              </div>
            )
          }
          {
            postEditors.length > 0 && (
              <div class="mt-8">
                <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
                  Tentang Editor
                </h3>
                <div class="grid gap-6">
                  {postEditors.map(
                    (editor) =>
                      editor && (
                        <div class="flex flex-col items-center text-center space-y-4 p-4 bg-gray-50 dark:bg-gray-800 rounded-lg md:flex-row md:items-start md:text-left md:space-y-0 md:space-x-4">
                          <div class="block md:flex-shrink-0">
                            {editor.data.avatar ? (
                              <img
                                src={editor.data.avatar}
                                alt={editor.data.name}
                                loading="lazy"
                                class="w-16 h-16 rounded-full object-cover"
                              />
                            ) : (
                              <div class="w-16 h-16 rounded-full bg-primary-600 flex items-center justify-center text-white text-xl font-medium">
                                {editor.data.name.charAt(0)}
                              </div>
                            )}
                          </div>
                          <div class="flex flex-col">
                            <h4 class="font-semibold text-gray-900 dark:text-white">
                              {editor.data.name}
                            </h4>
                            {editor.data.bio && (
                              <p class="text-gray-600 dark:text-gray-400 mt-1">
                                {editor.data.bio}
                              </p>
                            )}
                            {editor.data.social && (
                              <div class="flex space-x-3 mt-3 justify-center md:justify-start">
                                {/* Social Icons */}
                              </div>
                            )}
                          </div>
                        </div>
                      ),
                  )}
                </div>
              </div>
            )
          }
        </footer>

        <section class="mt-12">
          <h2 class="text-xl font-semibold mb-4">Lanjut Membaca</h2>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {
              bottomRelatedPosts.map((post, index) => (
                <a
                  href={`/${post.slug}/`}
                  class={`
                  block border rounded-lg p-4 shadow-sm hover:shadow-md transition
                  ${index > 1 ? "hidden md:block" : ""}
                  `}
                >
                  <h3 class="font-semibold text-lg">{post.data.title}</h3>
                  <p class="text-sm opacity-70 mt-1">{post.data.description}</p>
                </a>
              ))
            }
          </div>
        </section>
      </article>

      <!-- Sidebar (Desktop-only) -->
      <aside class="hidden lg:block lg:col-span-4">
        <div class="sticky top-8 space-y-8">
          <TableOfContents headings={headings} />
          <div class="bg-primary-50 dark:bg-primary-900/20 rounded-md p-6">
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-3"
            >
              Dukung Kami
            </h3>
            <p class="text-sm text-gray-600 dark:text-gray-400 mb-4">
              Sekecil apapun dukungan Anda, sangat berarti!
            </p>
            <a
              href="/#donasi/"
              class="hidden sm:inline-flex items-center bg-[#414071] hover:bg-[#414071] text-white text-sm font-medium px-4 py-2 rounded-md transition-colors duration-200"
              ><svg
                class="w-4 h-4 mr-2"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                ></path></svg
              >Dukung Kami</a
            >
          </div>

          <div class="bg-orange-50 dark:bg-gray-800 rounded-md p-6">
            <h3
              class="text-lg font-semibold text-gray-900 dark:text-white mb-4"
            >
              Artikel Lainnya
            </h3>
            <div class="space-y-2 text-sm">
              {
                sidebarRelatedPosts.map((r) => (
                  <div>
                    <a
                      href={`/${r.slug}/`}
                      class="text-gray-800 dark:text-gray-200 hover:underline"
                    >
                      {r.data.title}
                    </a>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>